    {
      "parameters": {
        "jsCode": "// Parsea la salida JSON del agente y la deja lista para el resto del flujo.\nlet raw = ($json.output || '').toString().trim();\nraw = raw.replace(/^```json/i, '').replace(/^```/, '').replace(/```$/, '').trim();\n\nlet parsed;\nlet parseOk = true;\ntry {\n  parsed = JSON.parse(raw);\n} catch (e) {\n  parseOk = false;\n  parsed = {\n    post: $json.output,\n    titular_fuente: '',\n    tema_principal: 'general',\n    keywords: '',\n    fuente_rss: '',\n    prompt_imagen: 'Ilustración digital plana sobre tecnología e inteligencia artificial para pymes, flat design, colores azul y blanco, sin texto, composición limpia tipo infografía conceptual'\n  };\n}\n\n// Fallback por si el agente devuelve JSON válido pero omite prompt_imagen\nif (!parsed.prompt_imagen) {\n  parsed.prompt_imagen = `Ilustración digital plana sobre ${parsed.tema_principal || 'tecnología e IA'}, flat design, colores azul y blanco, sin texto, composición limpia tipo infografía conceptual`;\n}\n\n// Validación de calidad: el post debe existir y tener cuerpo real\nconst postTexto = (parsed.post || '').toString().trim();\nconst postValido = parseOk && postTexto.length >= 80;\n\nparsed._valido = postValido;\nparsed._motivo = postValido ? '' : (parseOk ? 'post demasiado corto o vacío' : 'JSON inválido del agente');\n\nreturn [{ json: parsed }];"
      },
